# ===== Moravo =====
# Copie este arquivo para .env e ajuste os valores conforme o ambiente.
# cp .env.example .env

# Porta onde o Express escuta (o host geralmente faz proxy pra 80/443)
PORT=3000

# Banco Supabase Postgres
# DATABASE_URL=postgresql://postgres:SUA_SENHA@db.SEU_PROJETO.supabase.co:5432/postgres

# Origens permitidas pelo CORS.
# Como front e back estão no mesmo domínio, CORS é desnecessário.
# Em produção, deixe vazio. Use * só pra liberar geral durante desenvolvimento.
CORS_ORIGIN=

# Ambiente: development | production
NODE_ENV=production

# ===== JWT =====
# Segredo usado pra assinar/verificar tokens. Em produção, o servidor
# se recusa a subir se JWT_SECRET não estiver definido (fail-fast).
# Gere um valor único com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# TTL do token em horas (default 168 = 7 dias)
JWT_EXPIRES_IN=168
